{
  "name": "@gopherex/iam-sdk",
  "version": "1.3.6",
  "description": "TypeScript SDK for the IAM API, generated from openapi/openapi.yaml.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist src/gen",
    "prepack": "yarn generate && yarn build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.10.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gopherex/iam.git",
    "directory": "ts/packages/sdk"
  }
}
